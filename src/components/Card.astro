---
export interface CardLink {
  label: string;
  href: string;
}

export interface Props {
  name: string;
  title: string;
  links: CardLink[];
}

const { name, title, links } = Astro.props;
---
<div class="card-stage">
  <article class="card" id="card" data-state="A" aria-label="Profile card">
    <div class="card__face card__face--front" aria-hidden="false">
      <header>
        <h1>{name}</h1>
        <p class="card__sub">{title}</p>
      </header>
      <footer>
        <div class="card__controls">
          <button type="button" class="card__btn" data-flip>flip</button>
          <button type="button" class="card__btn" data-swipe-aside="right" aria-label="Move card aside">reveal &rarr;</button>
        </div>
        <p class="card__hint">scroll to flip · swipe to reveal</p>
      </footer>
    </div>
    <div class="card__face card__face--back" aria-hidden="true">
      <header>
        <h2>contact</h2>
      </header>
      <ul class="card__links">
        {links.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
      </ul>
      <footer>
        <p class="card__hint">scroll to flip back</p>
      </footer>
    </div>
  </article>
</div>

<style>
  .card h1 {
    font-size: 1.4rem;
    margin: 0;
    letter-spacing: 0.02em;
  }
  .card h2 {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0;
    color: #555;
  }
  .card__sub {
    margin: 0.4rem 0 0;
    opacity: 0.65;
    font-size: 0.9rem;
  }
  .card__hint {
    margin: 0;
    font-size: 0.7rem;
    opacity: 0.45;
    letter-spacing: 0.05em;
  }
  .card__controls {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .card__btn {
    font: inherit;
    font-size: 0.75rem;
    background: transparent;
    color: #111;
    border: 1px solid #ccc;
    padding: 0.35rem 0.7rem;
    cursor: pointer;
    letter-spacing: 0.05em;
  }
  .card__btn:hover,
  .card__btn:focus-visible {
    border-color: #111;
    outline: none;
  }
  .card__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .card__links a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 0, 0, 0.15);
    padding-bottom: 2px;
  }
  .card__links a:hover,
  .card__links a:focus-visible {
    border-color: #111;
    outline: none;
  }
</style>
