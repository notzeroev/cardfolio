---
import CardSlot from './CardSlot.astro';

// The card is a stack of numbered content slots. Fill as many as you like
// from the page (`<div slot="slot-0">…</div>`), each free to express
// anything within the card's bounds.
//
//   - Even slots (0, 2, 4) live on the FRONT face.
//   - Odd slots  (1, 3, 5) live on the BACK face.
//
// The scroll-driven flip walks through them in order (0 → 1 → 2 → …).
// The first present slot on each face is the one shown when that face is up.
const has = (i: number) => Astro.slots.has(`slot-${i}`);
const frontIdx = [0, 2, 4].filter(has);
const backIdx = [1, 3, 5].filter(has);
const firstFront = frontIdx[0];
const firstBack = backIdx[0];
---
<div class="card-stage">
  <article class="card" id="card" aria-label="Profile card">
    <div class="card__face card__face--front">
      {has(0) && <CardSlot index={0} active={firstFront === 0}><slot name="slot-0" /></CardSlot>}
      {has(2) && <CardSlot index={2} active={firstFront === 2}><slot name="slot-2" /></CardSlot>}
      {has(4) && <CardSlot index={4} active={firstFront === 4}><slot name="slot-4" /></CardSlot>}
    </div>
    <div class="card__face card__face--back" aria-hidden="true">
      {has(1) && <CardSlot index={1} active={firstBack === 1}><slot name="slot-1" /></CardSlot>}
      {has(3) && <CardSlot index={3} active={firstBack === 3}><slot name="slot-3" /></CardSlot>}
      {has(5) && <CardSlot index={5} active={firstBack === 5}><slot name="slot-5" /></CardSlot>}
    </div>
  </article>
</div>
