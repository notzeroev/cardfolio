---
import CardSlot from './CardSlot.astro';

// The card is a deck of numbered content cards, stacked like a fresh pack.
// Fill as many slots as you like from the page (`<div slot="slot-0">…</div>`).
//
// Scrolling shuffles the deck one card at a time: the front card slides out
// and tucks in at the back (Pokémon-pack style). Order is 0 → 1 → 2 → …,
// wrapping around.
const has = (i: number) => Astro.slots.has(`slot-${i}`);
const indices = [0, 1, 2, 3, 4, 5].filter(has);
const first = indices[0];
---
<div class="card-stage">
  <div class="deck" id="deck" role="group" aria-label="Profile cards">
    {has(0) && <CardSlot index={0} active={first === 0}><slot name="slot-0" /></CardSlot>}
    {has(1) && <CardSlot index={1} active={first === 1}><slot name="slot-1" /></CardSlot>}
    {has(2) && <CardSlot index={2} active={first === 2}><slot name="slot-2" /></CardSlot>}
    {has(3) && <CardSlot index={3} active={first === 3}><slot name="slot-3" /></CardSlot>}
    {has(4) && <CardSlot index={4} active={first === 4}><slot name="slot-4" /></CardSlot>}
    {has(5) && <CardSlot index={5} active={first === 5}><slot name="slot-5" /></CardSlot>}
  </div>
</div>
