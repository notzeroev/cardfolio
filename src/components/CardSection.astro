---
export interface Props {
  title: string;
  slotIndex: number;
  active?: boolean;
}

const { title, slotIndex, active = false } = Astro.props;
---
<div
  class:list={['face-slot', 'card-section', { 'face-slot--active': active }]}
  data-slot={slotIndex}
  aria-hidden={active ? 'false' : 'true'}
>
  <h2 class="card-section__title">{title}</h2>
  <div class="card-section__body">
    <slot />
  </div>
</div>
