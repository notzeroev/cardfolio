---
// A single card in the deck: a fixed-size white card the content fills.
// Whatever you drop inside is clipped to (and free to fill) that space.
export interface Props {
  index: number;
  active?: boolean;
}

const { index, active = false } = Astro.props;
---
<article
  class="deck-card"
  data-slot={index}
  inert={active ? undefined : true}
>
  <slot />
</article>
