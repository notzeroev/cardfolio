---
import Base from '../layouts/Base.astro';
import Card from '../components/Card.astro';
import ContentSection from '../components/ContentSection.astro';

const links = [
  { label: 'email', href: 'mailto:ashwinthisaiah@gmail.com' },
  { label: 'github', href: 'https://github.com/' },
  { label: 'substack', href: 'https://substack.com/' },
];
---
<Base title="Nathan Isaiah">
  <Card name="Nathan Isaiah" title="builds things" links={links} />
  <div class="scroll-spin" aria-hidden="true"></div>
  <div class="scroll-slide-out" aria-hidden="true"></div>
  <ContentSection />
  <div class="scroll-slide-in" aria-hidden="true"></div>
  <div class="scroll-infinite" aria-hidden="true"></div>
</Base>

<script>
  import { initCard } from '../scripts/card.ts';
  initCard();
</script>
