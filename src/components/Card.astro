---
import CardIntro from './CardIntro.astro';
import CardSection from './CardSection.astro';

export interface CardLink {
  label: string;
  href: string;
}

export interface Project {
  name: string;
  body: string;
}

export interface Props {
  name: string;
  about: string;
  projects: Project[];
  links: CardLink[];
  photo?: string;
}

const { name, about, projects, links, photo } = Astro.props;
---
<div class="card-stage">
  <article class="card" id="card" aria-label="Profile card">
    <div class="card__face card__face--front" aria-hidden="false">
      <CardIntro name={name} photo={photo} slotIndex={0} active={true} />
      <CardSection title="projects" slotIndex={2}>
        <div class="card-project">
          <h3>{projects[0].name}</h3>
          <p>{projects[0].body}</p>
        </div>
      </CardSection>
      <CardSection title="connect" slotIndex={4}>
        <ul>
          {links.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
        </ul>
      </CardSection>
    </div>
    <div class="card__face card__face--back" aria-hidden="true">
      <CardSection title="about" slotIndex={1} active={true}>
        <p>{about}</p>
      </CardSection>
      <CardSection title="projects" slotIndex={3}>
        <div class="card-project">
          <h3>{projects[1].name}</h3>
          <p>{projects[1].body}</p>
        </div>
      </CardSection>
    </div>
  </article>
</div>
